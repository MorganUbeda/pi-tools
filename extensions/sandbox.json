{
  "enabled": true,
  "allowBrowserProcess": true,
  "network": {
    "allowLocalBinding": true,
    "allowAllUnixSockets": true,
    "allowedDomains": ["*", "*.*", "*.*.*"],
    "deniedDomains": []
  },
  "filesystem": {
    "denyRead": [],
    "allowRead": [".", "~/.config", "~/.local", "Library"],
    "allowWrite": [".", "/tmp", "/var/folders", "~/.cache/uv"],
    "denyWrite": [".env", ".env.*", "*.pem", "*.key"]
  }
}
